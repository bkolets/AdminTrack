<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>AdminTrack Admin</label>
    <description>Grants full access to AdminTrack objects, Apex classes, and the setup LWC</description>
    <hasActivationRequired>false</hasActivationRequired>

    <!-- Object Permissions: AdminAuditLog__c (CRUD) -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>true</modifyAllRecords>
        <viewAllRecords>true</viewAllRecords>
        <object>AdminAuditLog__c</object>
    </objectPermissions>

    <!-- Object Permissions: AdminTrackExclusionRule__c (CRUD) -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>true</modifyAllRecords>
        <viewAllRecords>true</viewAllRecords>
        <object>AdminTrackExclusionRule__c</object>
    </objectPermissions>

    <!-- Field Permissions: AdminAuditLog__c (summary fields) -->
    <fieldPermissions>
        <editable>true</editable>
        <readable>true</readable>
        <field>AdminAuditLog__c.BatchRunDate__c</field>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <readable>true</readable>
        <field>AdminAuditLog__c.WindowStart__c</field>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <readable>true</readable>
        <field>AdminAuditLog__c.WindowEnd__c</field>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <readable>true</readable>
        <field>AdminAuditLog__c.TotalChanges__c</field>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <readable>true</readable>
        <field>AdminAuditLog__c.ExcludedCount__c</field>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <readable>true</readable>
        <field>AdminAuditLog__c.Details__c</field>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <readable>true</readable>
        <field>AdminAuditLog__c.SentToSlack__c</field>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <readable>true</readable>
        <field>AdminAuditLog__c.SlackSentDate__c</field>
    </fieldPermissions>

    <!-- Field Permissions: AdminTrackExclusionRule__c -->
    <fieldPermissions>
        <editable>true</editable>
        <readable>true</readable>
        <field>AdminTrackExclusionRule__c.ExclusionType__c</field>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <readable>true</readable>
        <field>AdminTrackExclusionRule__c.IsActive__c</field>
    </fieldPermissions>

    <!-- Field Permissions: AdminTrackSettings__c -->
    <fieldPermissions>
        <editable>true</editable>
        <readable>true</readable>
        <field>AdminTrackSettings__c.SlackMaxDetails__c</field>
    </fieldPermissions>

    <!-- Custom Setting: AdminTrackSettings__c (Read + Edit via setup UI) -->
    <customSettingAccesses>
        <enabled>true</enabled>
        <name>AdminTrackSettings__c</name>
    </customSettingAccesses>

    <!-- Tab Visibility -->
    <tabSettings>
        <tab>AdminTrack_Setup</tab>
        <visibility>Visible</visibility>
    </tabSettings>

    <!-- Apex Class Access -->
    <classAccesses>
        <apexClass>AdminTrackBatch</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AdminTrackExclusionService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AdminTrackLogService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AdminTrackScheduler</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AdminTrackSchedulerService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AdminTrackService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SlackNotificationService</apexClass>
        <enabled>true</enabled>
    </classAccesses>


</PermissionSet>
